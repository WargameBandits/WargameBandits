# 1. GitHub OAuth ID (일단 비워두거나 나중에 채우면 됨)
REACT_APP_GITHUB_CLIENT_ID=your_github_client_id_here

# 2. ★★★ 백엔드 API 주소 (제일 중요!) ★★★
# Vercel 대시보드에서 받은 주소를 넣으세요 (뒤에 /api나 /challenges 붙이지 마세요!)
# 예시: https://wargame-server.vercel.app
REACT_APP_API_URL=https://wargame-server.vercel.app

# 3. 로그인 후 돌아올 주소 (로컬 테스트용)
REACT_APP_REDIRECT_URI=http://localhost:3000/callback

