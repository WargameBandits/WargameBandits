# GitHub OAuth ID (지금은 몰라도 되니 그냥 둠)
REACT_APP_GITHUB_CLIENT_ID=your_github_oauth_app_client_id

# ★★★ 여기가 핵심! 님의 Render 주소로 변경 ★★★
# 주의: 뒤에 /api는 뺍니다! (우리 NestJS는 /api 없이 만들었으니까요)
REACT_APP_API_URL=https://wargame-server-gwol.onrender.com

# Redirect URI (일단 로컬 테스트용으로 둠)
REACT_APP_REDIRECT_URI=http://localhost:3000/callback


